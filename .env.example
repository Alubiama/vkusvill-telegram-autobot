BOT_TOKEN=
BOT_TOKEN_FILE=
CHAT_ID=
OWNER_USER_ID=
TIMEZONE=Europe/Moscow
COLLECTION_TIMES=00:00,00:05,10:00
ORDER_DEADLINE=19:30
PROVIDER=manual_json
DISCOUNTS_JSON_PATH=data/today_discounts.json
VKUSVILL_EXPECTED_DELIVERY=
RPA_COMMAND=.\.venv\Scripts\python.exe scripts\vkusvill_collect_discounts.py --source system_chrome --chrome-user-data-dir "data/chrome-user-data" --chrome-profile-name "Default" --headless --interactive-login --waves 3 --require-distinct-waves --offers-ready-food-url "https://vkusvill.ru/offers/gotovaya-eda/" --offers-ready-food-max 0 --expected-delivery-hint "%VKUSVILL_EXPECTED_DELIVERY%" --strict-delivery-check --out-file data\today_discounts.json
ORDER_EXECUTOR_COMMAND=.\.venv\Scripts\python.exe scripts\vkusvill_order_executor.py --order-file "{order_file}" --chrome-user-data-dir "data/chrome-user-data" --chrome-profile-name "Default" --headless
MINI_APP_URL=
DRY_RUN=true

OUT_DIR=X:\vkusvill-telegram-autobot\out
OUT_RETENTION_DAYS=30

AUTO_PUBLISH_PAGES=false
PUBLISH_PAGES_COMMAND=publish-github-pages.cmd

COLLECT_FAILOVER_ENABLED=false
FALLBACK_RPA_COMMAND=
FALLBACK_DISCOUNTS_JSON_PATH=
FAILOVER_MIN_REGULAR_ITEMS=18
FAILOVER_REQUIRE_MIN_REGULAR=false
COLLECT_MIN_ITEMS=10

VV_MOBILE_BASE_URL=https://mobile.vkusvill.ru
VV_MOBILE_ORDERS_PATH=/api/v1/orders
VV_MOBILE_UPDATE_TOKEN_PATH=/api/user/v1/updateToken
VV_ANON_TOKEN=
VV_ACCESS_TOKEN=
VV_REFRESH_TOKEN=
VV_CARD_NUMBER=
